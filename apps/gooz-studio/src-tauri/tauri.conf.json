{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "goozarapSessions",
  "version": "0.1.0",
  "identifier": "com.westerngazoo.goozarap",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "goozarapSessions",
